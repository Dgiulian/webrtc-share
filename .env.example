# WebRTC Share - Environment Variables

# ============================================
# Backend Configuration
# ============================================

# Server port (default: 8084)
PORT=8084

# ============================================
# Frontend Configuration
# ============================================

# WebSocket signaling server URL
# For local development:
VITE_SIGNALING_SERVER=ws://localhost:8084

# For production (Fly.io deployment):
# VITE_SIGNALING_SERVER=wss://your-app-name.fly.dev

# ============================================
# Optional: Deployment Configuration
# ============================================

# Fly.io app name (optional, used for deployment scripts)
# FLY_APP_NAME=webrtc-share-backend

# Frontend deployment URL (optional)
# VERCEL_URL=https://your-app.vercel.app